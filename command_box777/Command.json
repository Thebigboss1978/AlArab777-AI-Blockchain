function TypeWriter({ text, speed = 20, onDone }) {

  const [displayed, setDisplayed] = useState("");

  const idx = useRef(0);

  useEffect(() => {

    if (!text) return;

    idx.current = 0;

    setDisplayed("");

    const iv = setInterval(() => {

      idx.current++;

      setDisplayed(text.slice(0, idx.current));

      if (idx.current >= text.length) { clearInterval(iv); onDone?.(); }

    }, speed);

    return () => clearInterval(iv);

  }, [text]);

  return (

    <span style={{ whiteSpace: "pre-wrap" }}>

      {displayed}

      {displayed.length < (text?.length || 0) && (

        <span style={{ animation: "blink 0.8s step-end infinite" }}>▍</span>

      )}

    </span>

  );

}



async function fetchAgentMessage(agent) {

  try {

    const res = await fetch("https://api.anthropic.com/v1/messages", {

      method: "POST",

      headers: { "Content-Type": "application/json" },

      body: JSON.stringify({

        model: "claude-sonnet-4-5",

        max_tokens: 1000,

        messages: [{ role: "user", content: agent.prompt }]

      })

    });

    const data = await res.json();

    if (data.error) return `[${data.error.message}]`;

    return data.content?.[0]?.text || "...";

  } catch(e) {

    return "[connection error — but I'm still here.]";

  }

}



