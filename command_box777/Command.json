        await new Promise(r => setTimeout(r, i === 0 ? 300 : 500));

        setActiveAgent(i);

        setIsTypingAgent(true);

        const msg = await fetchAgentMessage(AGENTS[i]);

        setMessages(prev => ({ ...prev, [AGENTS[i].id]: msg }));

        setIsTypingAgent(false);

