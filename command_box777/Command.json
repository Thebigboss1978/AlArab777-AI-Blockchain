-- إنشاء لوحة النسر (ملء الشاشة وشفافة)
eagle = hs.canvas.new(hs.screen.mainScreen():frame())
eagle:insertElement({
    type = "rectangle",
    action = "fill",
    fillColor = {white=1, alpha=0.2}, -- شفافية 20% كما طلبت
    frame = {x=0, y=0, w="100%", h="100%"}
})

-- إضافة صورة النسر في المنتصف
eagle:insertElement({
    type = "image",
    image = hs.image.imageFromPath("/path/to/eagle.png"), -- ضع مسار صورة النسر هنا
    frame = {x="25%", y="25%", w="50%", h="50%"}
})

-- ربط الهرم بالنسر
pyramid:mouseCallback(function(canvas, event, id, x, y)
    if event == "mouseDown" then
        if eagle:isShowing() then eagle:hide() else eagle:show() end
    end
end)
