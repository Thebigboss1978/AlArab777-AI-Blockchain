    setBootLines([]);

    setMessages({});

    setActiveAgent(-1);

    setFinalLine(false);

    setIsTypingAgent(false);

    setPhase("boot");

    BOOT.forEach(({ text, delay }) => {

      setTimeout(() => setBootLines(prev => [...prev, text]), delay);

    });

    setTimeout(() => setPhase("reveal"), 3400);

  }, [replay]);



  useEffect(() => {

    if (phase === "reveal") setTimeout(() => setPhase("agents"), 700);

  }, [phase]);



