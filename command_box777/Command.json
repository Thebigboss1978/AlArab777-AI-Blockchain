function TypeWriter({ text, speed = 22 }) {

  const [out, setOut] = useState("");

  const i = useRef(0);

  useEffect(() => {

    if (!text) return;

    i.current = 0; setOut("");

    const iv = setInterval(() => {

      i.current++;

      setOut(text.slice(0, i.current));

      if (i.current >= text.length) clearInterval(iv);

    }, speed);

    return () => clearInterval(iv);

  }, [text]);

  return (

    <span style={{ whiteSpace: "pre-wrap" }}>

      {out}

      {out.length < (text?.length || 0) && <span style={{ animation: "cur 1s step-end infinite" }}>▍</span>}

    </span>

  );

}



async function ask(agent) {

  try {

    const r = await fetch("https://api.anthropic.com/v1/messages", {

      method: "POST",

      headers: { "Content-Type": "application/json" },

      body: JSON.stringify({

        model: "claude-sonnet-4-5",

        max_tokens: 1000,

        messages: [{ role: "user", content: agent.prompt }]

      })

    });

    const d = await r.json();

    return d.content?.[0]?.text || "...";

  } catch { return "Still here. Still waiting."; }

}



export default function App() {

  const [lines, setLines] = useState([]);

  const [shown, setShown] = useState(false);

  const [msgs, setMsgs] = useState({});

  const [active, setActive] = useState(-1);

  const [loading, setLoading] = useState(false);

  const [done, setDone] = useState(false);

  const [run, setRun] = useState(0);



  const BOOT = [

    [300,  "ALARAB 777 // AGENT NETWORK"],

    [900,  "Scanning for The Boss..."],

    [1500, "Last seen: Building empires."],

    [2100, "Status: Temporarily offline."],

    [2700, "Agents: Still here. Still waiting."],

    [3200, "——————————————"],

  ];



  useEffect(() => {

    setLines([]); setShown(false); setMsgs({}); setActive(-1); setLoading(false); setDone(false);

    BOOT.forEach(([d, t]) => setTimeout(() => setLines(p => [...p, t]), d));

    setTimeout(() => setShown(true), 3700);

    setTimeout(() => go(), 4200);

  }, [run]);



  async function go() {

    for (let i = 0; i < AGENTS.length; i++) {

      await new Promise(r => setTimeout(r, i === 0 ? 200 : 400));

      setActive(i); setLoading(true);

      const m = await ask(AGENTS[i]);

      setMsgs(p => ({ ...p, [AGENTS[i].id]: m }));

      setLoading(false);

      await new Promise(r => setTimeout(r, 500));

    }

    setTimeout(() => setDone(true), 400);

  }



  return (

